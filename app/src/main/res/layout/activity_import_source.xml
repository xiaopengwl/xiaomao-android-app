<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xm_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/xm_top_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/import_back_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/xm_toolbar_button_bg"
            android:contentDescription="@string/common_back"
            android:padding="9dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/xm_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/import_title"
            android:textColor="@color/xm_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/import_save_button"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="@string/import_save"
            android:textAllCaps="false"
            android:textColor="@color/xm_accent_dark"
            app:backgroundTint="@color/xm_accent"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/import_summary"
                android:textColor="@color/xm_text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/import_title_hint"
                app:boxBackgroundColor="@color/xm_surface"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/xm_stroke_soft"
                app:hintTextColor="@color/xm_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/import_title_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/xm_text_primary"
                    android:textColorHint="@color/xm_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/import_host_hint"
                app:boxBackgroundColor="@color/xm_surface"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/xm_stroke_soft"
                app:hintTextColor="@color/xm_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/import_host_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/xm_text_primary"
                    android:textColorHint="@color/xm_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/import_rule_hint"
                app:boxBackgroundColor="@color/xm_surface"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/xm_stroke_soft"
                app:hintTextColor="@color/xm_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/import_raw_input"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:overScrollMode="always"
                    android:scrollbars="vertical"
                    android:textColor="@color/xm_text_primary"
                    android:textColorHint="@color/xm_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
