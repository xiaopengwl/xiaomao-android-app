<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xm_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/xm_top_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/settings_back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/xm_toolbar_button_bg"
            android:contentDescription="@string/common_back"
            android:padding="9dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/xm_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textColor="@color/xm_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_done_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/settings_done"
            android:textAllCaps="false"
            android:textColor="@color/xm_accent_dark"
            app:backgroundTint="@color/xm_accent"
            app:cornerRadius="10dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/xm_surface"
                app:cardCornerRadius="10dp"
                app:strokeColor="@color/xm_stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_summary"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/settings_night_mode_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/settings_night_mode"
                        android:textColor="@color/xm_text_primary"
                        android:textSize="16sp"
                        app:useMaterialThemeColors="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/settings_night_mode_desc"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/xm_stroke" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/settings_remember_source_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/settings_remember_source"
                        android:textColor="@color/xm_text_primary"
                        android:textSize="16sp"
                        app:useMaterialThemeColors="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/settings_remember_source_desc"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/xm_stroke" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/settings_default_library_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/settings_default_library"
                        android:textColor="@color/xm_text_primary"
                        android:textSize="16sp"
                        app:useMaterialThemeColors="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/settings_default_library_desc"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/xm_stroke" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/settings_keep_search_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/settings_keep_search"
                        android:textColor="@color/xm_text_primary"
                        android:textSize="16sp"
                        app:useMaterialThemeColors="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/settings_keep_search_desc"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/xm_surface"
                app:cardCornerRadius="10dp"
                app:strokeColor="@color/xm_stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_about_title"
                        android:textColor="@color/xm_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/settings_app_version"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/xm_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/settings_app_core"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/settings_app_support"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/xm_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
