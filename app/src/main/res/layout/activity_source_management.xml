<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#081018"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111B21"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/source_manage_back_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/source_manage_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/source_manage_import_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/source_manage_import"
            android:textAllCaps="false"
            android:textColor="#042111"
            app:backgroundTint="#1FCB63"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/source_manage_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:text="@string/source_manage_title"
        android:textColor="#98B2A7"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/source_manage_settings_button"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:text="@string/source_manage_open_settings"
        android:textAllCaps="false"
        android:textColor="#DDF4E5"
        app:cornerRadius="16dp"
        app:strokeColor="#2A6340" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/source_manage_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp" />

</LinearLayout>
