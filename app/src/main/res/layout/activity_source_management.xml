<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xm_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/xm_top_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/source_manage_back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/xm_toolbar_button_bg"
            android:contentDescription="@string/common_back"
            android:padding="9dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/xm_text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/source_manage_title"
                android:textColor="@color/xm_text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/source_manage_subtitle"
                android:textColor="@color/xm_text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/source_manage_import_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/source_manage_import"
            android:textAllCaps="false"
            android:textColor="@color/xm_accent_dark"
            app:backgroundTint="@color/xm_accent"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/xm_surface"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/xm_stroke_soft"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/source_manage_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/source_manage_title"
                android:textColor="@color/xm_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/source_manage_active_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/source_manage_active_source_empty"
                android:textColor="@color/xm_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/source_manage_subtitle"
                android:textColor="@color/xm_text_muted"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/source_manage_settings_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="12dp"
                android:text="@string/source_manage_open_settings"
                android:textAllCaps="false"
                android:textColor="@color/xm_text_primary"
                app:cornerRadius="8dp"
                app:strokeColor="@color/xm_stroke_soft" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/source_manage_empty_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/xm_surface"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/xm_stroke_soft"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="24dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/source_manage_empty_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/main_msg_no_source"
                android:textColor="@color/xm_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/source_manage_empty_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/source_manage_import"
                android:textAllCaps="false"
                android:textColor="@color/xm_accent_dark"
                app:backgroundTint="@color/xm_accent"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/source_manage_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp" />

</LinearLayout>
