<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#111B21"
    app:cardCornerRadius="22dp"
    app:strokeColor="#1F3A2A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/source_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/source_item_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#9CB7AB"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/source_item_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#183024"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="@string/source_manage_type_builtin"
            android:textColor="#BFE7CB"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/source_item_select_button"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/source_manage_select_action"
                android:textAllCaps="false"
                android:textColor="#042111"
                app:backgroundTint="#1FCB63"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/source_item_delete_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:text="@string/source_manage_delete_confirm"
                android:textAllCaps="false"
                android:textColor="#F7CBCB"
                app:cornerRadius="14dp"
                app:strokeColor="#804040" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/source_item_test_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="@string/source_manage_test_action"
                android:textAllCaps="false"
                android:textColor="#DDF4E5"
                app:cornerRadius="14dp"
                app:strokeColor="#2A6340" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/source_item_debug_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/source_manage_debug_action"
                android:textAllCaps="false"
                android:textColor="#DDF4E5"
                app:cornerRadius="14dp"
                app:strokeColor="#2A6340" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
