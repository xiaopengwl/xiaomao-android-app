<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="315"
                android:endColor="@color/xm_surface"
                android:startColor="@color/xm_surface_elevated" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="11dp" />
            <gradient
                android:angle="270"
                android:endColor="@color/xm_surface"
                android:startColor="@color/xm_overlay_card" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="@color/xm_stroke_soft" />
        </shape>
    </item>
</layer-list>
